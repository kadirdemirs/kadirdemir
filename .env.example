# ─────────────────────────────────────────────────
# Kadir Demir — environment configuration
# ─────────────────────────────────────────────────

# MongoDB Atlas (zorunlu)
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/kadirdemir?retryWrites=true&w=majority

# Admin auth — en az 32 karakter rastgele değer (zorunlu)
JWT_SECRET=change-me-to-a-random-secret-with-32-plus-chars

# CORS — virgülle ayrılmış origin listesi
ALLOWED_ORIGINS=http://localhost:5173,https://kadirardademir.com

# Public canonical URL — sitemap, RSS, email link, OG meta için kullanılır
SITE_BASE_URL=https://kadirardademir.com

# ─────────────────────────────────────────────────
# E-posta (SMTP) — iletişim formu, newsletter
# ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_TO=your-email@gmail.com

# ─────────────────────────────────────────────────
# YouTube Data API v3 (yeni)
# https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# ─────────────────────────────────────────────────
# Google Analytics 4
# Frontend (gtag) için Measurement ID:
VITE_GA_ID=G-XXXXXXXXXX
# Admin panel sunucu tarafı GA4 Data API için (opsiyonel):
GA4_PROPERTY_ID=
GA4_CLIENT_EMAIL=
GA4_PRIVATE_KEY=

# ─────────────────────────────────────────────────
# Newsletter double opt-in / unsubscribe token
# (opsiyonel — JWT_SECRET'a fallback)
# ─────────────────────────────────────────────────
NEWSLETTER_SECRET=change-me-newsletter-secret-32-plus-chars
UNSUBSCRIBE_SECRET=change-me-unsubscribe-secret-32-plus-chars

# ─────────────────────────────────────────────────
# Vercel cron / seed güvenliği
# ─────────────────────────────────────────────────
# Comment moderation: when set to "on", new comments are hidden until an admin approves
COMMENTS_MODERATION=off

CRON_SECRET=change-me-cron-secret-32-plus-chars
CRON_SIGNATURE_SECRET=change-me-cron-signature-32-plus-chars
VERCEL_WEBHOOK_SECRET=change-me-webhook-secret-32-plus-chars
SEED_SECRET=change-me-seed-secret-32-plus-chars
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ENDPOINT_ENABLED=false

# ─────────────────────────────────────────────────
# Rate limit (Upstash Redis — opsiyonel, prod için önerilir)
# ─────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────
# WhatsApp bildirimi (opsiyonel)
# ─────────────────────────────────────────────────
WA_PHONE=
WA_APIKEY=

# ─────────────────────────────────────────────────
# PWA Push Bildirimleri — Web Push (VAPID)
# Üret: npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────
VAPID_PUBLIC_KEY=buraya-vapid-public-key-gir
VAPID_PRIVATE_KEY=buraya-vapid-private-key-gir

# ─────────────────────────────────────────────────
# IndexNow — Blog yayınlandığında Bing/Yandex anlık indeksleme
# Key üret: node -e "console.log(require('crypto').randomUUID().replace(/-/g,''))"
# Aynı key'i public/[KEY].txt dosyasına da yaz (Bing doğrulaması)
# ─────────────────────────────────────────────────
INDEXNOW_KEY=buraya-indexnow-key-gir
